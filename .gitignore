# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# Linux port build artifacts (post-migration from monolithic script).
# Source lives under linux/ as real files; these dirs are regenerated
# on every cargo/cmake invocation.
linux/**/target/
linux/amwall-gui-qt/build/
# Generated from /sys/kernel/btf/vmlinux by aya-tool at build time —
# kernel-version-specific, regenerated on every linux-build.sh run.
linux/amwall-ebpf/src/vmlinux.rs

# Phase 6.10: linux/vendor/ and linux/amwall-ebpf/vendor/ are
# INTENTIONALLY TRACKED — they hold offline-cached crate sources so
# `cargo build --frozen --offline` works on air-gapped boxes and the
# build can't drift if a dep is yanked from crates.io. linux/Cargo.lock
# and linux/amwall-ebpf/Cargo.lock are also tracked for the same
# reason (frozen resolution). Do NOT add `vendor/` or `Cargo.lock`
# here. Re-vendor with `cargo vendor --versioned-dirs vendor` in each
# workspace dir whenever a Cargo.toml changes.

# Bootstrap script's tee log + paste-back files used during dev iteration.
amwall-run.log
mintlog.txt

# One-shot migration helpers (kept locally for reference but never shipped).
.migrate_extract.py
.migrate_slim.py

# Editor / IDE
# `.vscode/` is intentionally tracked — we ship project-specific
# build tasks (Ctrl+Shift+B builds the MSI installer, the
# build-and-run-elevated task, the WiX prerequisites check) so
# contributors pick up the same workflow on first checkout. Keep
# per-user overrides + IntelliSense / history caches out:
.vscode/*.local
.vscode/.history/
.idea/
.claude/
*.swp
*.swo
*~

# Windows
Thumbs.db
Desktop.ini
*.pdb

# Build artifacts
*.exe
*.dll
*.lib
*.exp
*.obj

# Local config / secrets
.env
.env.local
*.local

# Debug dumps left by `netsh wfp show filters` etc.
/filters.xml
/wfpstate.xml

# stderr capture from VS Code build-and-run task.
/swaplog.txt

# Locale audit (internal review, not published)
locales/localeanalysis.md
locales/localechecks.md
